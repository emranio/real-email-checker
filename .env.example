# Frontend -> backend API endpoint (same-origin when served by Node)
VITE_SMTP_VERIFY_ENDPOINT=/api/smtp/verify

# Frontend timeout for SMTP verify API request
VITE_SMTP_VERIFY_TIMEOUT_SECONDS=20

# Node backend settings
PORT=8081
SMTP_TIMEOUT_SECONDS=20
# SMTP_HELO_HOST=mail.yourdomain.com
# SMTP_MAIL_FROM=verify@yourdomain.com

# Auth settings
AUTH_SIGNUP_ENABLED=true
JWT_SECRET=replace-this-in-production-with-a-long-secret
JWT_EXPIRES_IN=7d
SQLITE_DB_PATH=./data/app.sqlite3

# Whether to keep email logs in the database (for debugging and auditing purposes).
KEEP_EMAIL_LOG=false

# Background validation scheduler
MAX_CONCURRENT_RUNS=5
RUN_WORKER_CONCURRENCY=20
SCHEDULER_POLL_MS=2000
DNS_TIMEOUT_MS=5000
MAX_INPUT_EMAILS=100000
